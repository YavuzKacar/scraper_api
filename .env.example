# Copy to .env and fill in real values. See API_DOCUMENTATION.md for details.
# .env is auto-loaded by config.py (python-dotenv); real environment
# variables, if set, always take precedence over values in .env.

# ── Security ──────────────────────────────────────────────────────────────
SCRAPER_API_KEY=change-me-immediately

# ── Server ────────────────────────────────────────────────────────────────
SCRAPER_HOST=127.0.0.1
SCRAPER_PORT=8000

# ── Database ──────────────────────────────────────────────────────────────
SCRAPER_DB_PATH=scraper_metadata.db

# ── Tor ───────────────────────────────────────────────────────────────────
TOR_SOCKS_HOST=127.0.0.1
TOR_SOCKS_PORT=9150
TOR_CONTROL_PORT=9151
TOR_CONTROL_PASSWORD=
# Leave TOR_EXE_PATH / FIREFOX_BINARY_PATH unset to use config.py's defaults.
# Uncomment only if your Tor Browser install lives somewhere non-default.
# TOR_EXE_PATH=C:\path\to\tor.exe
# FIREFOX_BINARY_PATH=C:\path\to\Tor Browser\Browser\firefox.exe

# ── Scraper behaviour ─────────────────────────────────────────────────────
RETRY_COUNT=3
DOMAIN_RATE_LIMIT_SECONDS=2.0
REQUEST_TIMEOUT=30.0
MAX_CONCURRENT_SCRAPES=10
RESULT_CACHE_TTL_SECONDS=600

# ── Credits ───────────────────────────────────────────────────────────────
INITIAL_CREDITS=10000

# ── Scheduler ─────────────────────────────────────────────────────────────
SCHEDULER_INTERVAL_SECONDS=300

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs

# ── Request safety limits ────────────────────────────────────────────────
MAX_RESPONSE_SIZE_BYTES=20000000
MAX_PAGE_LOAD_SECONDS=45.0

# ── SSRF protection / allow-block list ───────────────────────────────────
SSRF_PROTECTION_ENABLED=true
# Comma-separated domains; seeds data/url_lists.json on first run only.
URL_ALLOWLIST=
URL_BLOCKLIST=

# ── Fallback providers ────────────────────────────────────────────────────
SCRAPE_DO_API_KEY=
SCRAPE_DO_BASE_URL=https://api.scrape.do
ZYTE_API_KEY=
ZYTE_BASE_URL=https://api.zyte.com/v1/extract

# ── Per-provider cost (USD-equivalent credits) ───────────────────────────
# Placeholder figures -- tune to your real provider pricing.
COST_STATIC=0.001
COST_BROWSER=0.01
COST_TOR=0.02
COST_SCRAPE_DO=0.05
COST_ZYTE=0.08
